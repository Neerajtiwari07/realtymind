# Email provider: console | gmail | sendgrid | smtp
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=noreply@realtymind.local

# Common SMTP settings (used for gmail/sendgrid/smtp providers)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# Gmail example:
# EMAIL_PROVIDER=gmail
# EMAIL_HOST_USER=yourgmail@gmail.com
# EMAIL_HOST_PASSWORD=your_gmail_app_password
# DEFAULT_FROM_EMAIL=yourgmail@gmail.com

# SendGrid example:
# EMAIL_PROVIDER=sendgrid
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your_sendgrid_api_key
# DEFAULT_FROM_EMAIL=verified_sender@yourdomain.com
